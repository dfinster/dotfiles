#!/bin/zsh
#
# dotfiles - Manage dotfiles repository with subcommands
#
# Usage:
#   dotfiles update    - Apply dotfiles updates from GitHub
#   dotfiles check     - Check for available updates and notify
#   dotfiles --help    - Show help information
#

# Show help function
_dotfiles_help() {
    echo "Usage: dotfiles <command>"
    echo
    echo "Commands:"
    echo "  update    Apply dotfiles updates from GitHub"
    echo "  check     Check for available updates and notify"
    echo "  help      Show this help message"
    echo
    echo "Environment Variables:"
    echo "  DOTFILES_BRANCH    Target branch for updates (default: main)"
    echo "  DOTFILES           Path to dotfiles directory"
}

# Common setup function
_dotfiles_setup() {
    # Exit early if DOTFILES environment variable is not set
    if [[ -z "$DOTFILES" ]]; then
        return 1
    fi

    # Exit early if dotfiles directory doesn't exist
    if [[ ! -d "$DOTFILES" ]]; then
        return 1
    fi

    # Change to dotfiles directory
    pushd "$DOTFILES" >/dev/null || return 1

    # Exit early if not in a git repository
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        popd >/dev/null
        return 1
    fi

    # Determine target branch from DOTFILES_BRANCH (default to main)
    target_branch="${DOTFILES_BRANCH:-main}"

    # Get current branch
    current_branch=$(git branch --show-current)

    return 0
}

# Switch to target branch if needed
_dotfiles_switch_branch() {
    if [[ "$current_branch" != "$target_branch" ]]; then
        if [[ "$1" == "verbose" ]]; then
            echo "🔄 Switching to branch '$target_branch'..."
        fi
        if ! git checkout "$target_branch" >/dev/null 2>&1; then
            if [[ "$1" == "verbose" ]]; then
                echo "❌ Failed to switch to branch '$target_branch'"
            fi
            popd >/dev/null
            return 1
        fi
    fi
    return 0
}

# Check for updates function
_dotfiles_check() {
    local target_branch current_branch

    # Setup common variables
    if ! _dotfiles_setup; then
        return 0
    fi

    # Switch to target branch
    if ! _dotfiles_switch_branch; then
        return 0
    fi

    # Check cache file to avoid frequent network operations
    local cache_file="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles-check-cache"
    local cache_duration=43200  # 12 hours in seconds

    # If not manual check, skip fetch if cache is recent
    if [[ "$1" != "manual" ]]; then
        # Skip fetch if we've checked recently
        if [[ -f "$cache_file" ]]; then
            local cache_time=$(stat -f %m "$cache_file" 2>/dev/null || echo 0)
            local current_time=$(date +%s)
            if (( current_time - cache_time < cache_duration )); then
                popd >/dev/null
                return 0
            fi
        fi
    fi

    # Check if we can reach GitHub (fail silently if offline)
    if ! git ls-remote origin >/dev/null 2>&1; then
        popd >/dev/null
        return 0
    fi

    # Fetch latest remote information
    git fetch origin "$target_branch" >/dev/null 2>&1

    # Update cache file to record successful check
    mkdir -p "$(dirname "$cache_file")"
    touch "$cache_file"

    # Check if local branch is behind remote (lightweight check first)
    local commits_behind
    commits_behind=$(git rev-list --count HEAD..origin/"$target_branch")

    # Exit early if up to date (most common case)
    if [[ "$commits_behind" -eq 0 ]]; then
        if [[ "$1" == "manual" ]]; then
            echo "On branch $target_branch:\033[93m Your dotfiles are up to date.\033[0m"
        fi
        popd >/dev/null
        return 0
    fi

    # Show what's new and prompt user to run update
    echo
    echo "Using branch: \033[93m$target_branch\033[0m"
    echo "\033[93mA dotfiles update is available.\033[0m"
    echo "You are \033[93m${commits_behind}\033[0m commit(s) behind the remote."
    echo
    echo "- See changelog at '\033[93mhttps://github.com/dfinster/dotfiles/blob/$target_branch/CHANGELOG.md\033[0m' for details."
    echo "- Run '\033[93mdotfiles update\033[0m' to apply the update."

    popd >/dev/null
}

# Update function
_dotfiles_update() {
    local target_branch current_branch

    # Setup common variables
    if ! _dotfiles_setup; then
        return 0
    fi

    # Switch to target branch with verbose output
    if ! _dotfiles_switch_branch verbose; then
        return 1
    fi

    # Check if we can reach GitHub (fail silently if offline)
    if ! git ls-remote origin >/dev/null 2>&1; then
        popd >/dev/null
        return 0
    fi

    # Fetch latest remote information
    git fetch origin "$target_branch" >/dev/null 2>&1

    # Check if local branch is ahead of remote
    local commits_ahead commits_behind
    commits_ahead=$(git rev-list --count origin/"$target_branch"..HEAD)
    commits_behind=$(git rev-list --count HEAD..origin/"$target_branch")

    # Exit if not behind remote (either up to date or ahead)
    if [[ "$commits_behind" -eq 0 ]]; then
        echo "You have the latest dotfiles."
        popd >/dev/null
        return 0
    fi

    # Apply the update
    echo "📦 Updating dotfiles..."

    # Stash any local changes
    local stash_created=false
    if ! git diff-index --quiet HEAD --; then
        git stash push -m "Auto-stash before dotfiles update $(date)"
        stash_created=true
        echo "💾 Local changes stashed."
    fi

    # Pull latest changes
    if git pull origin "$target_branch"; then
        echo "✅ Dotfiles updated successfully!"

        # Update antidote plugins if antidote is available
        if command -v antidote >/dev/null 2>&1; then
            echo
            echo "🔌 Updating antidote plugins..."
            if antidote update >/dev/null 2>&1; then
                echo "✅ antidote plugins updated"
            else
                echo "⚠️  antidote plugin update failed, but dotfiles update succeeded"
            fi
        fi

        echo
        echo "🔄 Please restart your terminal to apply all changes."
        echo -n "Press Enter to continue..."
        read -r

    else
        echo "❌ Update failed!"

        # Restore stashed changes if we created a stash
        if [[ "$stash_created" == "true" ]]; then
            git stash pop
            echo "💾 Local changes restored."
        fi

        popd >/dev/null
        return 1
    fi

    popd >/dev/null
}

# Main function
case "$1" in
    update)
        _dotfiles_update
        ;;
    # undocumented alias for silent checks in shell startup
    autocheck)
        _dotfiles_check
        ;;
    check)
        _dotfiles_check manual
        ;;
    help|--help|-h|"")
        _dotfiles_help
        ;;
    *)
        echo "Error: Unknown command '$1'"
        echo
        _dotfiles_help
        return 1
        ;;
esac
